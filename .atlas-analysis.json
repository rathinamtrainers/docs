  "keyFeatures": [
    "Learner self-registration with email verification",
    "Secure email/password login with JWT access tokens",
    "Refresh token rotation for seamless session management",
    "Self-service password reset via email link",
    "Brute-force protection with automatic account lockout",
    "Server-side token revocation on logout and password reset",
    "Role-based access (learner, instructor, admin)",
    "DPDPA 2023 and GDPR-aligned PII handling"
  ],
  "publicApiSurface": [
    "POST /auth/register",
    "GET /auth/verify-email?token=",
    "POST /auth/login",
    "POST /auth/refresh",
    "POST /auth/logout",
    "POST /auth/password-reset/request",
    "POST /auth/password-reset/confirm"
  ]
